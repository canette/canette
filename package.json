{
  "name": "canette",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run --cwd apps/api dev",
    "dev:ui": "bun run --cwd apps/ui dev",
    "dev:docs": "bun run --cwd apps/docs dev",
    "build:ui": "bun run --cwd apps/ui build",
    "build:api": "bun run --cwd apps/api build",
    "build:api:migrate": "bun run --cwd apps/api build:migrate",
    "build:docs": "bun run --cwd apps/docs build",
    "test:api": "bun test --cwd apps/api",
    "lint:ui": "bun run --cwd apps/ui lint",
    "lint:api": "bun run --cwd apps/api lint",
    "lint:docs": "bun run --cwd apps/docs lint",
    "lint:builder": "cd apps/builder && golangci-lint run",
    "lint:controller": "cd apps/controller && golangci-lint run",
    "lint:logstreamer": "cd apps/logstreamer && golangci-lint run",
    "test:builder": "cd apps/builder && go test ./...",
    "test:controller": "cd apps/controller && go test ./...",
    "test:logstreamer": "cd apps/logstreamer && go test ./...",
    "typecheck": "bunx tsc --build apps/api/tsconfig.json apps/ui/tsconfig.json packages/types/tsconfig.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
