# Copy to .env and fill in values before running.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# For local dev: port-forward the in-cluster PostgreSQL (see labs/postgres.yaml):
#   kubectl port-forward -n canette-system svc/postgres 5432:5432
DATABASE_URL=postgresql://canette:canette@localhost:5432/canette

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Auth (better-auth) ────────────────────────────────────────────────────────
# Secret used to sign session tokens — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Must match the public URL of the UI (used for CORS and auth redirects).
BETTER_AUTH_URL=http://localhost:3000
UI_URL=http://localhost:3000

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM master key for encrypting credentials, secrets, and webhook secrets.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── GitHub OAuth login (optional) ─────────────────────────────────────────────
# Enables the "Continue with GitHub" button on the login page.
# Create an OAuth App at https://github.com/settings/developers.
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── GitHub App (optional) ─────────────────────────────────────────────────────
# Enables the cluster-wide GitHub App git credential type.
# See docs/configuration/github-app for setup instructions.
# The private key can be pasted as-is (multi-line) in a .env file.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
# System credential mode: admin installs the app once, all teams share it.
GITHUB_APP_INSTALLATION_ID=
# Per-team installation wizard: users connect their own GitHub accounts/orgs.
# GITHUB_APP_PUBLIC_LINK is the "Public link" shown in your GitHub App settings.
# Accepts either the full URL (https://github.com/apps/my-app) or just the slug (my-app).
# In your GitHub App settings, set the "Setup URL" (under Post installation) to:
#   http://localhost:3001/api/v1/github-app/callback  (local dev)
#   https://canette.example.com/api/v1/github-app/callback  (production)
GITHUB_APP_PUBLIC_LINK=

# ── Logstreamer ───────────────────────────────────────────────────────────────
# Internal URL of the logstreamer service (not publicly exposed).
LOGSTREAMER_URL=http://localhost:8082
# Shared secret — must match LOGSTREAMER_SECRET in the logstreamer process.
# Generate with: openssl rand -hex 32
LOGSTREAMER_SECRET=

# ── Default resource allocations ──────────────────────────────────────────────
# Applied to every app deployment unless overridden by canette.yaml.
# Uses standard Kubernetes quantity notation (100m, 256Mi, etc.).
DEFAULT_CPU_REQUEST=100m
DEFAULT_MEMORY_REQUEST=128Mi
DEFAULT_CPU_LIMIT=500m
DEFAULT_MEMORY_LIMIT=512Mi

# ── Webhook base URL (optional) ───────────────────────────────────────────────
# Public base URL used to construct webhook payload URLs registered with git
# providers. Defaults to UI_URL when not set. Only needed if your API is
# accessible at a different hostname than the UI.
# Example: https://api.example.com
WEBHOOK_BASE_URL=
