{
  "name": "@canette/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --compile --outfile api-server",
    "build:migrate": "bun build scripts/migrate.ts --target=bun --compile --outfile db-migrate",
    "db:migrate": "bun run scripts/migrate.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@canette/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-auth": "^1.6.11",
    "hono": "4.12.18",
    "jose": "^6.2.3",
    "js-yaml": "^4.1.1",
    "kysely": "^0.29.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.11.0",
    "bun-types": "^1.3.13",
    "eslint": "^10.3.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
