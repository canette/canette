{
  "name": "@canette/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build --target=bun --compile --outfile api-server src/index.ts",
    "db:migrate": "bun run scripts/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@canette/types": "workspace:*",
    "better-auth": "^1.2.0",
    "hono": "^4.12.0",
    "kysely": "^0.28.16",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.11.0",
    "typescript": "^5.6.0"
  }
}
