# Controller — local development environment
# Copy to .env and fill in the required values.
# Keep the PostgreSQL port-forward running before starting:
#   kubectl port-forward -n canette-system svc/postgres 5432:5432
#
# Derive the node IP and registry hostname:
#   NODE_IP=$(kubectl get nodes -o jsonpath='{.items[0].status.addresses[?(@.type=="InternalIP")].address}')
#   REGISTRY_HOST="registry.$(echo $NODE_IP | tr . -).traefik.me"

# Required
ENCRYPTION_KEY=          # 64-char hex; copy from apps/api/.env
PULL_REPO=               # e.g. registry.<node-ip>.traefik.me:32500/  (kubelet-accessible registry)
CLUSTER_DOMAIN=          # e.g. 192-168-64-2.traefik.me  (NODE_IP with dots replaced by dashes)

# Optional (shown with their defaults)
DATABASE_URL=postgresql://canette:canette@localhost:5432/canette
GATEWAY_NAME=can-gateway
GATEWAY_NAMESPACE=kube-system
BUILDER_NAMESPACE=canette-build
POLL_INTERVAL=5s
LOG_TAIL_INTERVAL=10s
MAX_CONCURRENT=3
# KUBECONFIG=~/.kube/config
