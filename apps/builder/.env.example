# Builder — local development environment
# Copy to .env and fill in the required values.
# Keep the PostgreSQL port-forward running before starting:
#   kubectl port-forward -n canette-system svc/postgres 5432:5432

# Required
ENCRYPTION_KEY=          # 64-char hex; copy from apps/api/.env
IMAGE_REPO=registry.canette-system.svc.cluster.local:5000/
BUILDER_IMAGE=           # e.g. registry.<node-ip>.traefik.me:32500/canette-builder-image-build:latest
GIT_INIT_IMAGE=          # e.g. registry.<node-ip>.traefik.me:32500/canette-builder-git-init:latest

# Optional (shown with their defaults)
DATABASE_URL=postgresql://canette:canette@localhost:5432/canette
BUILDER_NAMESPACE=canette-build
BUILDKITD_ADDR=tcp://buildkitd.canette-build.svc.cluster.local:1234
REGISTRY_AUTH_SECRET=    # name of the dockerconfigjson Secret in BUILDER_NAMESPACE; leave empty for unauthenticated
POLL_INTERVAL=5s
MAX_CONCURRENT=3
LOG_LEVEL=info           # debug | info | warn | error
# KUBECONFIG=~/.kube/config
